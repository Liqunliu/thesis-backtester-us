# Tushare Pro API token (required)
# Get yours at: https://tushare.pro/register
TUSHARE_TOKEN=your_token_here

# LLM API (required for agent-analyze)
# Supports any OpenAI-compatible API provider
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Provider examples:
# OpenAI:    LLM_BASE_URL=https://api.openai.com/v1
# DeepSeek:  LLM_BASE_URL=https://api.deepseek.com/v1
# Qwen:      LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Moonshot:  LLM_BASE_URL=https://api.moonshot.cn/v1
# GLM:       LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Ollama:    LLM_BASE_URL=http://localhost:11434/v1
